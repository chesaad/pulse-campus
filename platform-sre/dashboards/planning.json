{
  "id": null,
  "uid": "devhub-planning",
  "title": "DevHub Campus — planning (RED)",
  "tags": [
    "devhub-campus",
    "tp3",
    "planning"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(http_requests_total, namespace)",
          "refId": "namespace"
        },
        "current": {
          "text": "devhub-dev",
          "value": "devhub-dev"
        },
        "refresh": 2,
        "includeAll": false
      },
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(http_requests_total{namespace=\"$namespace\"}, service)",
          "refId": "service"
        },
        "current": {
          "text": "planning",
          "value": "planning"
        },
        "refresh": 2,
        "includeAll": false
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(http_requests_total{service=\"$service\", namespace=\"$namespace\"}, instance)",
          "refId": "instance"
        },
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "includeAll": true
      },
      {
        "name": "build_info_metric",
        "type": "constant",
        "query": "planning_build_info",
        "current": {
          "text": "planning_build_info",
          "value": "planning_build_info"
        },
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (RPS)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"$service\", namespace=\"$namespace\"}[5m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx %)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{service=\"$service\", namespace=\"$namespace\", status_class=\"5xx\"}[5m]))\n/\nsum(rate(http_requests_total{service=\"$service\", namespace=\"$namespace\"}[5m]))",
          "legendFormat": "erreur 5xx",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latence p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=\"$service\", namespace=\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"$service\", namespace=\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"$service\", namespace=\"$namespace\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Build info (version active)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "expr": "{__name__=~\"$build_info_metric\", namespace=\"$namespace\"}",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
